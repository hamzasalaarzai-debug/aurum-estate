const PROPS=[
  {id:1,nm:"Hilltop Luxury Villa",area:"Hayatabad Ph.6, Peshawar",price:45000000,status:"sale",beds:5,baths:4,size:"10 Marla",parking:2,type:"Villa",cat:"villa",bdg:"PREMIUM",bcls:"bp",img:"1600607687939-ce8a6c25118c",desc:"A masterpiece of modern architecture set on an elevated site in prestigious Hayatabad Phase 6. Features panoramic city views, Italian marble flooring, a private gym, landscaped garden and a solar power system. Double-height entrance lobby with designer fixtures throughout."},
  {id:2,nm:"Garden Estate",area:"F-7/3, Islamabad",price:85000000,status:"sale",beds:6,baths:5,size:"1 Kanal",parking:4,type:"House",cat:"residential",bdg:"EXCLUSIVE",bcls:"be",img:"1600596542815-ffad4c1539a9",desc:"An exclusive estate in the most coveted F-7 sector of Islamabad. Surrounded by mature trees, featuring a chef's kitchen, private cinema room, staff quarters and a meticulously maintained garden with a heated pool. One of Islamabad's finest addresses."},
  {id:3,nm:"Sky Penthouse 3601",area:"E-11, Islamabad",price:32000000,status:"sale",beds:3,baths:3,size:"3,200 sqft",parking:2,type:"Penthouse",cat:"penthouse",bdg:"NEW",bcls:"bn",img:"1560448204-e02f11c3d0e2",desc:"An ultra-modern penthouse on the 36th floor offering uninterrupted 360° views of the Margalla Hills and Islamabad skyline. Floor-to-ceiling glazing, a private wraparound terrace, premium smart home automation and designer Italian interiors throughout."},
  {id:4,nm:"DHA Corner Plot",area:"DHA Phase 2, Peshawar",price:9500000,status:"sale",beds:0,baths:0,size:"10 Marla",parking:0,type:"Residential Plot",cat:"plot",bdg:"HOT",bcls:"bh",img:"1500382017468-9049fed747ef",desc:"A prime corner plot in prestigious DHA Phase 2 Peshawar. Ideal for constructing a luxury double-storey residence. All utilities available. Close to Phase 2 gate with excellent road access. Title is clear with possession ready."},
  {id:5,nm:"Centaurus Business Suite",area:"Blue Area, Islamabad",price:28000000,status:"sale",beds:0,baths:2,size:"2,400 sqft",parking:3,type:"Office",cat:"commercial",bdg:"COMMERCIAL",bcls:"bc",img:"1486406146926-c627a92ad1ab",desc:"A premium commercial suite in the heart of Islamabad's Blue Area business district. Floor-to-ceiling windows, raised flooring for cabling, 3 executive cabins, a boardroom for 12, a reception and dedicated covered parking."},
  {id:6,nm:"Riverside Grand Villa",area:"University Town, Peshawar",price:55000000,status:"sale",beds:5,baths:4,size:"1 Kanal",parking:3,type:"Villa",cat:"villa",bdg:"PREMIUM",bcls:"bp",img:"1512917774080-9991f1c4c750",desc:"A prestigious grand villa in the leafy University Town. Private swimming pool, landscaped gardens, a home theatre, imported hardwood panelling, designer bathrooms and 24/7 guarded access with CCTV throughout."},
  {id:7,nm:"Capital Heights 2BR",area:"G-13, Islamabad",price:350000,status:"rent",beds:2,baths:2,size:"1,200 sqft",parking:1,type:"Apartment",cat:"apartment",bdg:"FOR RENT",bcls:"br",img:"1545324418-cc1a3fa10c00",desc:"A beautifully furnished 2-bedroom apartment in the rapidly developing G-13 sector. Modern interiors, balcony with scenic views, 24-hour concierge, backup generator and proximity to the best schools and Islamabad Expressway."},
  {id:8,nm:"Heritage Farmhouse",area:"Charsadda Road, Peshawar",price:75000000,status:"sale",beds:6,baths:5,size:"4 Kanal",parking:6,type:"Farmhouse",cat:"residential",bdg:"EXCLUSIVE",bcls:"be",img:"1564013799919-ab600027ffc6",desc:"A sprawling heritage-inspired farmhouse retreat. Lush 4-Kanal grounds with private orchards, a serviced guest wing, a large open-air entertainment pavilion with sound system, and traditional-meets-modern architecture. The ultimate family estate."},
  {id:9,nm:"Bahria Twin Peak",area:"Bahria Phase 4, Islamabad",price:38000000,status:"sale",beds:4,baths:3,size:"10 Marla",parking:2,type:"House",cat:"residential",bdg:"NEW",bcls:"bn",img:"1568605114967-8130f3a36994",desc:"A brand-new double-storey residence in Bahria Town Phase 4. Contemporary design, modular kitchen, marble and engineered wood interiors, and full access to all Bahria Town community facilities."},
  {id:10,nm:"Saddar Commercial Plaza",area:"Saddar, Peshawar",price:120000000,status:"sale",beds:0,baths:6,size:"8,000 sqft",parking:10,type:"Plaza",cat:"commercial",bdg:"LANDMARK",bcls:"bm",img:"1486325212027-8081e485255e",desc:"A fully rented commercial landmark in the heart of Saddar, Peshawar. G+3 with 12 commercial units, all leased to established businesses. Generating PKR 90 Lakh annual rental income. An exceptional investment property."},
  {id:11,nm:"Margalla View Plot",area:"E-7, Islamabad",price:18000000,status:"sale",beds:0,baths:0,size:"1 Kanal",parking:0,type:"Residential Plot",cat:"plot",bdg:"MARGALLA",bcls:"bm",img:"1505691723518-36a5ac3be353",desc:"A rare residential plot in exclusive E-7 with direct, unobstructed Margalla Hills views. Elevated site with natural breeze and stunning sunset orientation. Minutes from key Islamabad landmarks."},
  {id:12,nm:"Executive Penthouse F-10",area:"F-10 Markaz, Islamabad",price:900000,status:"rent",beds:3,baths:2,size:"1,800 sqft",parking:2,type:"Penthouse",cat:"penthouse",bdg:"FOR RENT",bcls:"br",img:"1493809842364-78817add7ffb",desc:"A high-floor executive apartment with panoramic Islamabad views, fully furnished with designer furniture and smart home controls. Dedicated maid's room, gym access, rooftop access and two covered parking bays."},
  {id:13,nm:"Summit Residence",area:"Warsak Road, Peshawar",price:28000000,status:"sale",beds:4,baths:3,size:"8 Marla",parking:2,type:"Villa",cat:"villa",bdg:"PREMIUM",bcls:"bp",img:"1582407947304-fd86f28320c7",desc:"A refined modern villa with a European-inspired façade and a rooftop terrace offering sweeping Peshawar city views. Designer interiors with custom joinery, imported fittings and a beautiful landscaped garden."},
  {id:14,nm:"Tech Hub Office",area:"I-9 Industrial, Islamabad",price:15000000,status:"sale",beds:0,baths:3,size:"3,000 sqft",parking:5,type:"Office",cat:"commercial",bdg:"CORNER",bcls:"bn",img:"1504384308090-c5d1a1571a49",desc:"A purpose-built, tech-ready commercial space in Islamabad's I-9 zone. Open-plan with high-speed fibre, modular workstations, a server room, a glass boardroom and 5 dedicated covered parking spaces. Ideal for IT companies."},
  {id:15,nm:"Pearl Residency",area:"Regi Model Town, Peshawar",price:19000000,status:"sale",beds:4,baths:3,size:"8 Marla",parking:2,type:"House",cat:"residential",bdg:"NEW",bcls:"bn",img:"1502005097973-6a7082348e28",desc:"A freshly constructed contemporary residence in the fast-growing Regi Model Town. Premium fixtures, solar panels, CCTV and walking distance from shopping centres, schools and hospitals."},
  {id:16,nm:"Grand Kanal Mansion",area:"DHA Phase 2, Islamabad",price:150000000,status:"sale",beds:7,baths:6,size:"2 Kanal",parking:6,type:"Mansion",cat:"residential",bdg:"ULTRA LUX",bcls:"bu",img:"1416331108676-a22ccb276e35",desc:"The crown jewel of our portfolio. An ultra-luxury 2-Kanal mansion in DHA Islamabad's most exclusive address. Indoor heated pool, private cinema, passenger elevator, 4-car underground garage, full smart home system and backup generator. Unrivalled in every regard."}
];

let saved=[],inquired=[],activeTab="all",sortBy="feat",maxP=200000000,searchQ="";

/* ——— FILTER ——— */
function getFiltered(){
  return PROPS.filter(p=>{
    if(activeTab==="sale"&&p.status!=="sale")return false;
    if(activeTab==="rent"&&p.status!=="rent")return false;
    if(["villa","apartment","commercial","plot","penthouse","residential"].includes(activeTab)&&p.cat!==activeTab)return false;
    if(p.status==="sale"&&p.price>maxP)return false;
    if(searchQ&&!p.nm.toLowerCase().includes(searchQ)&&!p.area.toLowerCase().includes(searchQ)&&!p.type.toLowerCase().includes(searchQ))return false;
    return true;
  }).sort((a,b)=>{
    if(sortBy==="lo")return a.price-b.price;
    if(sortBy==="hi")return b.price-a.price;
    if(sortBy==="new")return b.id-a.id;
    return a.id-b.id;
  });
}

/* ——— CARD TEMPLATE ——— */
function cardTpl(p,i){
  const isSaved=saved.some(s=>s.id===p.id);
  const mi=[];
  if(p.beds>0)mi.push(`<span class="pc-mi"><svg viewBox="0 0 24 24"><path d="M2 4v16M2 8h20M20 4v16M6 12h6"/></svg>${p.beds} Beds</span>`);
  if(p.baths>0)mi.push(`<span class="pc-mi"><svg viewBox="0 0 24 24"><path d="M4 12h16v3a4 4 0 0 1-4 4H8a4 4 0 0 1-4-4v-3z"/><path d="M6 12V5a2 2 0 0 1 2-2h3"/></svg>${p.baths} Baths</span>`);
  mi.push(`<span class="pc-mi"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="1"/><path d="M3 9h18M9 21V9"/></svg>${p.size}</span>`);
  return `<div class="pc" data-id="${p.id}" style="animation:cin .4s ease-out ${i*.045}s both">
    <div class="pc-img">
      <img src="${IU(p.img,800,500)}" alt="${p.nm}" loading="lazy"/>
      <div class="pc-bdg-row">
        <span class="cbdg ${p.bcls}">${p.bdg}</span>
        <div class="pc-acts">
          <button class="abtn sv-btn ${isSaved?'won':''}" data-id="${p.id}" title="Save"><svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></button>
          <button class="abtn qv-btn" data-id="${p.id}" title="Quick View"><svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></button>
        </div>
      </div>
      <div class="pc-status">${p.status==='rent'?'For Rent':'For Sale'}</div>
    </div>
    <div class="pc-body">
      <div class="pc-type">${p.type}</div>
      <div class="pc-name">${p.nm}</div>
      <div class="pc-price">${fmt(p.price,p.status)}</div>
      <div class="pc-loc"><svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>${p.area}</div>
      <div class="pc-meta">${mi.join('')}</div>
      <button class="pc-inq iq-btn" data-id="${p.id}">Inquire Now</button>
    </div>
  </div>`;
}
/* cin keyframe */
const st=document.createElement('style');
st.textContent='@keyframes cin{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:none}}';
document.head.appendChild(st);

function renderGrid(){
  const g=document.getElementById("pgrid");
  const ps=getFiltered();
  document.getElementById("rsc").textContent=ps.length+" propert"+(ps.length===1?"y":"ies")+" found";
  if(!ps.length){g.innerHTML=`<div class="no-res"><p>No properties match your criteria.</p></div>`;return;}
  g.innerHTML=ps.map((p,i)=>cardTpl(p,i)).join('');
  g.querySelectorAll(".sv-btn").forEach(b=>b.addEventListener("click",e=>{e.stopPropagation();toggleSave(+b.dataset.id);}));
  g.querySelectorAll(".iq-btn").forEach(b=>b.addEventListener("click",e=>{e.stopPropagation();addInq(+b.dataset.id);}));
  g.querySelectorAll(".qv-btn").forEach(b=>b.addEventListener("click",e=>{e.stopPropagation();openModal(+b.dataset.id);}));
  g.querySelectorAll(".pc").forEach(c=>c.addEventListener("click",()=>openModal(+c.dataset.id)));
}

/* ——— SAVE ——— */
function toggleSave(id){
  const p=PROPS.find(x=>x.id===id);
  const idx=saved.findIndex(s=>s.id===id);
  if(idx>-1){saved.splice(idx,1);toast("Removed from saved","warn");}
  else{saved.push(p);toast("Property saved ♡","ok");}
  updateBdg("wl-cnt",saved.length);renderGrid();renderSaved();
}
function renderSaved(){
  const b=document.getElementById("wl-body");
  if(!saved.length){b.innerHTML=`<div class="sb-empty"><svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg><p>No saved<br/>properties yet</p></div>`;return;}
  b.innerHTML=saved.map(p=>`<div class="wl-item"><div class="sb-thumb"><img src="${IU(p.img,160,120)}" alt="" loading="lazy"/></div><div><div class="sb-nm">${p.nm}</div><div class="sb-loc">${p.area}</div><div class="sb-price">${fmt(p.price,p.status)}</div><button class="sb-inq" onclick="addInq(${p.id})">Add to Inquiry</button></div><button class="sb-rm" onclick="toggleSave(${p.id})"><svg viewBox="0 0 24 24"><path d="M18 6 6 18M6 6l12 12"/></svg></button></div>`).join('');
}

/* ——— INQUIRY ——— */
function addInq(id){
  const p=PROPS.find(x=>x.id===id);
  if(inquired.some(i=>i.id===id)){toast("Already in list","warn");return;}
  inquired.push(p);updateBdg("iq-cnt",inquired.length);renderInq();toast("Added to inquiry list","ok");
}
function removeInq(id){inquired=inquired.filter(i=>i.id!==id);updateBdg("iq-cnt",inquired.length);renderInq();}
function renderInq(){
  const b=document.getElementById("iq-body");
  document.getElementById("iq-count").textContent=inquired.length;
  if(!inquired.length){b.innerHTML=`<div class="sb-empty"><svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg><p>No properties<br/>added yet</p></div>`;return;}
  b.innerHTML=inquired.map(p=>`<div class="iq-item"><div class="sb-thumb"><img src="${IU(p.img,160,120)}" alt="" loading="lazy"/></div><div style="flex:1"><div class="sb-nm">${p.nm}</div><div class="sb-loc">${p.area}</div><div class="sb-price">${fmt(p.price,p.status)}</div></div><button class="sb-rm" onclick="removeInq(${p.id})"><svg viewBox="0 0 24 24"><path d="M18 6 6 18M6 6l12 12"/></svg></button></div>`).join('');
}
function sendIqWa(){
  if(!inquired.length){toast("Add properties first","warn");return;}
  let msg="Hi+Aurum+Estates+Group!%0A%0AI+am+interested+in+the+following+properties:%0A%0A";
  inquired.forEach((p,i)=>{msg+=`${i+1}.+*${p.nm.replace(/ /g,"+")}*%0A%E2%80%83${p.area.replace(/ /g,"+")}%0A%E2%80%83${fmt(p.price,p.status).replace(/ /g,"+")}%0A%0A`;});
  msg+="Please+contact+me+with+details+and+arrange+site+visits.+Thank+you!";
  window.open(`https://wa.me/${WA}?text=${msg}`,"_blank");
  toast("Opening WhatsApp…","wa");
}

/* ——— MODAL ——— */
function openModal(id){
  const p=PROPS.find(x=>x.id===id);
  const imgs=[p.img,...gal(p.id)];
  document.getElementById("pm-main").src=IU(imgs[0],900,500);
  document.getElementById("pm-thumbs").innerHTML=imgs.map((im,i)=>`<img class="pm-th${i===0?' ac':''}" src="${IU(im,300,200)}" loading="lazy" onclick="swTh(this,'${im}')" alt=""/>`).join('');
  document.getElementById("pm-bdg").className=`cbdg ${p.bcls}`;
  document.getElementById("pm-bdg").textContent=p.bdg;
  document.getElementById("pm-type").textContent=p.type;
  document.getElementById("pm-name").textContent=p.nm;
  document.getElementById("pm-price").textContent=fmt(p.price,p.status);
  document.getElementById("pm-loc").textContent=p.area;
  const facts=[];
  if(p.beds>0)facts.push(`<div class="pm-fact"><div class="pm-fv">${p.beds}</div><div class="pm-fl">Bedrooms</div></div>`);
  if(p.baths>0)facts.push(`<div class="pm-fact"><div class="pm-fv">${p.baths}</div><div class="pm-fl">Bathrooms</div></div>`);
  facts.push(`<div class="pm-fact"><div class="pm-fv" style="font-size:15px">${p.size}</div><div class="pm-fl">Total Area</div></div>`);
  if(p.parking>0)facts.push(`<div class="pm-fact"><div class="pm-fv">${p.parking}</div><div class="pm-fl">Parking</div></div>`);
  facts.push(`<div class="pm-fact"><div class="pm-fv" style="font-size:13px;text-transform:capitalize">${p.status==='rent'?'For Rent':'For Sale'}</div><div class="pm-fl">Status</div></div>`);
  document.getElementById("pm-facts").innerHTML=facts.join('');
  document.getElementById("pm-desc").textContent=p.desc;
  document.getElementById("pm-inq-btn").onclick=()=>addInq(p.id);
  document.getElementById("pm-wa-btn").onclick=()=>{
    const msg=`Hi+Aurum+Estates!+I+am+interested+in+*${p.nm.replace(/ /g,"+")}*+in+${p.area.replace(/ /g,"+")}+(${fmt(p.price,p.status).replace(/ /g,"+")}).+Please+send+more+details.`;
    window.open(`https://wa.me/${WA}?text=${msg}`,"_blank");
  };
  document.getElementById("pmod").classList.add("open");
  document.getElementById("ovl").classList.add("on");
  document.body.style.overflow="hidden";
}
function swTh(el,id){document.getElementById("pm-main").src=IU(id,900,500);document.querySelectorAll(".pm-th").forEach(t=>t.classList.remove("ac"));el.classList.add("ac");}
function closeModal(){document.getElementById("pmod").classList.remove("open");document.getElementById("ovl").classList.remove("on");document.body.style.overflow="";}

/* ——— SIDEBARS ——— */
function openWl(){renderSaved();document.getElementById("wlsb").classList.add("open");document.getElementById("ovl").classList.add("on");document.body.style.overflow="hidden";}
function closeWl(){document.getElementById("wlsb").classList.remove("open");document.getElementById("ovl").classList.remove("on");document.body.style.overflow="";}
function openIq(){renderInq();document.getElementById("iqsb").classList.add("open");document.getElementById("ovl").classList.add("on");document.body.style.overflow="hidden";}
function closeIq(){document.getElementById("iqsb").classList.remove("open");document.getElementById("ovl").classList.remove("on");document.body.style.overflow="";}

/* ——— HELPERS ——— */
function updateBdg(id,n){const el=document.getElementById(id);el.textContent=n;el.classList.toggle("on",n>0);}
let toastT;
function toast(msg,type="ok"){const el=document.getElementById("toast");el.textContent=msg;el.className="on "+type;clearTimeout(toastT);toastT=setTimeout(()=>el.className="",2800);}
function ctaSubmit(){const v=document.getElementById("cta-inp").value.trim();if(!v){toast("Please enter your number","warn");return;}const msg=`Hi+Aurum+Estates!+I+submitted+my+number+${v.replace(/ /g,"+")}+for+a+free+site+visit.+Please+call+me.`;window.open(`https://wa.me/${WA}?text=${msg}`,"_blank");document.getElementById("cta-inp").value="";toast("Sent! We'll call you shortly.","wa");}
function closeMob(){document.getElementById("mob").classList.remove("open");}
function heroSearch(){const q=document.getElementById("h-inp").value.trim();if(q){searchQ=q.toLowerCase();}document.getElementById("shop").scrollIntoView({behavior:"smooth"});renderGrid();}
function quickFilter(t){const catMap={villa:"villa",apartment:"apartment",commercial:"commercial",islamabad:"all",peshawar:"all"};const srchMap={islamabad:"islamabad",peshawar:"peshawar",villa:"",apartment:"",commercial:""};activeTab=catMap[t]||"all";searchQ=srchMap[t]||"";document.querySelectorAll(".tab").forEach(tb=>tb.classList.toggle("on",tb.dataset.tab===activeTab));renderGrid();document.getElementById("shop").scrollIntoView({behavior:"smooth"});}
function cUp(id,target,sfx,spd){const el=document.getElementById(id);if(!el)return;let c=0;const step=Math.ceil(target/spd);const ti=setInterval(()=>{c=Math.min(c+step,target);el.textContent=c+sfx;if(c>=target)clearInterval(ti);},28);}

/* ——— INIT ——— */
document.addEventListener("DOMContentLoaded",()=>{

  /* Loader */
  let pct=0;const lt=setInterval(()=>{pct=Math.min(100,pct+Math.floor(Math.random()*7)+3);document.getElementById("ldpct").textContent=pct+"%";if(pct>=100)clearInterval(lt);},72);

  /* Hero */
  setTimeout(()=>{
    ["hlbl","hsub","hsearch"].forEach(id=>{const el=document.getElementById(id);if(el)el.classList.add("v");});
    document.querySelectorAll(".htl,.h-em").forEach(el=>el.classList.add("v"));
    cUp("hs1",500,"+",50);cUp("hs2",1200,"+",60);cUp("hs3",16,"",38);
    cUp("hk1",500,"+",50);cUp("hk2",1200,"+",60);cUp("hk3",16,"",38);
  },3100);

  /* Hero slide dots */
  let dotI=0;
  setInterval(()=>{
    dotI=(dotI+1)%3;
    document.querySelectorAll(".h-dot").forEach((d,i)=>d.classList.toggle("on",i===dotI));
  },8000);

  renderGrid();

  /* Cursor */
  const cur=document.getElementById("cur"),cur2=document.getElementById("cur2");
  let cx=innerWidth/2,cy=innerHeight/2,rx=cx,ry=cy;
  document.addEventListener("mousemove",e=>{cx=e.clientX;cy=e.clientY;cur.style.left=cx+"px";cur.style.top=cy+"px";});
  (function a(){rx+=(cx-rx)*.1;ry+=(cy-ry)*.1;cur2.style.left=rx+"px";cur2.style.top=ry+"px";requestAnimationFrame(a);})();
  document.querySelectorAll("a,button,.pc,.ccat,.stt,.feat-body").forEach(el=>{el.addEventListener("mouseenter",()=>document.body.classList.add("ch"));el.addEventListener("mouseleave",()=>document.body.classList.remove("ch"));});

  /* Scroll progress */
  window.addEventListener("scroll",()=>{const st=document.documentElement.scrollTop,h=document.documentElement.scrollHeight-innerHeight;document.getElementById("prog").style.width=(h?st/h*100:0)+"%";});

  /* Tabs */
  document.getElementById("tabs").addEventListener("click",e=>{const t=e.target.closest(".tab");if(!t)return;document.querySelectorAll(".tab").forEach(x=>x.classList.remove("on"));t.classList.add("on");activeTab=t.dataset.tab;renderGrid();});

  /* Sort */
  document.getElementById("sortsel").addEventListener("change",e=>{sortBy=e.target.value;renderGrid();});

  /* Price slider */
  const sl=document.getElementById("pslide");
  sl.addEventListener("input",()=>{maxP=sl.value>=100?200000000:sl.value*2000000;document.getElementById("pval").textContent=sl.value>=100?"No Limit":"Up to PKR "+(maxP/10000000).toFixed(0)+" Cr";renderGrid();});

  /* Search */
  document.getElementById("srch").addEventListener("input",e=>{searchQ=e.target.value.toLowerCase().trim();renderGrid();});

  /* Categories */
  document.querySelectorAll(".ccat").forEach(el=>{el.addEventListener("click",()=>{document.querySelectorAll(".ccat").forEach(c=>c.classList.remove("ac"));el.classList.add("ac");activeTab=el.dataset.cat;document.querySelectorAll(".tab").forEach(t=>t.classList.toggle("on",t.dataset.tab===activeTab));renderGrid();document.getElementById("shop").scrollIntoView({behavior:"smooth"});});});

  /* Sidebars */
  document.getElementById("wl-open").addEventListener("click",openWl);
  document.getElementById("iq-open").addEventListener("click",openIq);
  document.getElementById("wl-cls").addEventListener("click",closeWl);
  document.getElementById("iq-cls").addEventListener("click",closeIq);
  document.getElementById("pm-cls").addEventListener("click",closeModal);
  document.getElementById("ovl").addEventListener("click",()=>{closeModal();closeWl();closeIq();closeMob();});

  /* Mobile menu */
  document.getElementById("hambtn").addEventListener("click",()=>document.getElementById("mob").classList.add("open"));
  document.getElementById("mobcls").addEventListener("click",closeMob);

  /* Stats observer */
  new IntersectionObserver(entries=>{if(entries[0].isIntersecting){cUp("s1",500,"+",55);cUp("s2",1200,"+",65);cUp("s3",16,"",40);}},{threshold:.3}).observe(document.getElementById("stats"));

  /* GSAP */
  if(typeof gsap!=="undefined"&&typeof ScrollTrigger!=="undefined"){
    gsap.registerPlugin(ScrollTrigger);
    const ease="power3.out";
    gsap.utils.toArray(".ccat").forEach((el,i)=>gsap.from(el,{scrollTrigger:{trigger:"#cats",start:"top 82%"},opacity:0,y:38,duration:.7,delay:i*.07,ease}));
    gsap.utils.toArray(".pc").forEach((el,i)=>gsap.from(el,{scrollTrigger:{trigger:"#shop",start:"top 86%"},opacity:0,y:28,duration:.6,delay:i*.04,ease}));
    gsap.utils.toArray(".stt").forEach((el,i)=>gsap.from(el,{scrollTrigger:{trigger:"#stats",start:"top 85%"},opacity:0,y:24,duration:.6,delay:i*.1,ease}));
    gsap.utils.toArray(".fitm").forEach((el,i)=>gsap.from(el,{scrollTrigger:{trigger:"#features",start:"top 82%"},opacity:0,x:-22,duration:.6,delay:i*.09,ease}));
    gsap.utils.toArray(".rv").forEach((el,i)=>gsap.from(el,{scrollTrigger:{trigger:"#reviews",start:"top 85%"},opacity:0,y:26,duration:.6,delay:i*.08,ease}));
    gsap.from(".ceo-photo",{scrollTrigger:{trigger:"#ceo",start:"top 78%"},opacity:0,x:-40,duration:.9,ease});
    gsap.from(".ceo-body",{scrollTrigger:{trigger:"#ceo",start:"top 78%"},opacity:0,x:40,duration:.9,delay:.15,ease});
    gsap.from(".feat-body",{scrollTrigger:{trigger:"#featured",start:"top 80%"},opacity:0,x:50,duration:.9,ease});
    gsap.from(".cta-ttl",{scrollTrigger:{trigger:"#cta",start:"top 80%"},opacity:0,y:36,duration:.8,ease});
    gsap.from("#trust",{scrollTrigger:{trigger:"#trust",start:"top 90%"},opacity:0,y:16,duration:.5,ease});
  }
});
</script>
</body>
</html>
