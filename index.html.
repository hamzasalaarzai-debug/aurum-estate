<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>AURUM ESTATES GROUP — Luxury Real Estate | Islamabad & Peshawar</title>
<meta name="description" content="Pakistan's premier luxury real estate group. Exclusive villas, apartments, plots and commercial properties. CEO: Hamza Salarzai."/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Bebas+Neue&family=Space+Mono:wght@400;700&family=Barlow+Condensed:wght@200;300;400;500;700&display=swap"/>
<style>
:root{--blk:#060504;--wht:#ede8df;--cream:#d9d0c1;--gld:#b8963e;--gld2:#d0a845;--gldx:rgba(184,150,62,.1);--plat:#6e6860;--dark:#0d0c0a;--mid:#171410;--warm:#1f1c16;--bdr:rgba(255,255,255,.06);--gbdr:rgba(184,150,62,.24);--gsw:rgba(184,150,62,.07)}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{background:var(--blk);color:var(--wht);font-family:"Barlow Condensed",sans-serif;overflow-x:hidden;cursor:none}
body::before{content:"";position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.88' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.035'/%3E%3C/svg%3E");pointer-events:none;z-index:9990;opacity:.28}

/* LOADER */
#loader{position:fixed;inset:0;z-index:99999;background:var(--blk);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;animation:ldout .7s ease-in 3s forwards}
@keyframes ldout{to{opacity:0;visibility:hidden;pointer-events:none}}
.ld-emblem{position:relative;width:64px;height:64px;display:flex;align-items:center;justify-content:center;animation:ldup .5s ease-out .05s both}
.ld-emblem::before{content:"";position:absolute;inset:0;border:1px solid rgba(184,150,62,.2);transform:rotate(45deg)}
.ld-emblem::after{content:"";position:absolute;inset:10px;border:1px solid rgba(184,150,62,.1);transform:rotate(45deg)}
.ld-emblem svg{width:26px;height:26px;stroke:var(--gld);fill:none;stroke-width:1.3;position:relative;z-index:1}
.ld-name{font-family:"Bebas Neue",sans-serif;font-size:42px;letter-spacing:16px;color:var(--wht);animation:ldup .5s ease-out .15s both}
.ld-name span{color:var(--gld)}
.ld-serif{font-family:"Cormorant Garamond",serif;font-size:11px;letter-spacing:10px;color:var(--gld);font-style:italic;opacity:.7;animation:ldup .4s ease-out .25s both}
.ld-city{font-family:"Space Mono",monospace;font-size:7px;letter-spacing:7px;color:var(--plat);animation:ldup .4s ease-out .32s both}
.ld-track{width:180px;height:1px;background:rgba(184,150,62,.08);margin-top:8px;animation:ldup .4s ease-out .4s both}
.ld-fill{height:100%;background:var(--gld);box-shadow:0 0 10px rgba(184,150,62,.6);animation:ldfill 2.5s cubic-bezier(.4,0,.2,1) .45s both}
.ld-pct{font-family:"Space Mono",monospace;font-size:8px;letter-spacing:4px;color:var(--plat);animation:ldup .4s ease-out .5s both}
@keyframes ldup{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}
@keyframes ldfill{0%{width:0}65%{width:74%}90%{width:96%}100%{width:100%}}

/* CURSOR */
#cur,#cur2{position:fixed;border-radius:50%;pointer-events:none;transform:translate(-50%,-50%);z-index:99998}
#cur{width:6px;height:6px;background:var(--gld)}
#cur2{width:30px;height:30px;border:1px solid rgba(184,150,62,.3);transition:width .22s,height .22s,border-color .22s}
body.ch #cur2{width:52px;height:52px;border-color:var(--gld)}
#prog{position:fixed;top:0;left:0;height:2px;width:0%;background:linear-gradient(90deg,var(--gld),var(--gld2));z-index:10000;box-shadow:0 0 6px var(--gld)}

/* ANNOUNCEMENT */
#ann{background:var(--gld);padding:8px 0;overflow:hidden;z-index:999;position:relative}
.ann-in{display:inline-flex;animation:mq 50s linear infinite;white-space:nowrap}
.ann-in span{font-family:"Space Mono",monospace;font-size:8px;letter-spacing:4px;padding:0 26px;color:var(--blk)}
@keyframes mq{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

/* MOBILE MENU */
#mob{position:fixed;inset:0;z-index:6000;background:var(--blk);transform:translateX(-100%);transition:transform .55s cubic-bezier(.77,0,.175,1);display:flex;flex-direction:column;justify-content:center;padding:56px 48px;border-right:1px solid var(--bdr)}
#mob.open{transform:none}
#mob .m-lbl{font-family:"Space Mono",monospace;font-size:7px;letter-spacing:8px;color:var(--gld);opacity:.6;margin-bottom:28px}
#mob a{font-family:"Cormorant Garamond",serif;font-size:54px;font-weight:300;font-style:italic;color:var(--wht);text-decoration:none;display:block;line-height:1.15;transition:color .2s}
#mob a:hover{color:var(--gld)}
#mob .m-div{width:40px;height:1px;background:var(--bdr);margin:28px 0}
#mob .m-wa{display:inline-flex;align-items:center;gap:10px;padding:12px 24px;background:#25D366;font-family:"Bebas Neue",sans-serif;font-size:18px;letter-spacing:4px;color:var(--wht);text-decoration:none}
#mob .m-wa svg{width:16px;height:16px;fill:var(--wht)}
#mobcls{position:absolute;top:24px;right:24px;background:none;border:1px solid var(--bdr);width:40px;height:40px;display:flex;align-items:center;justify-content:center;cursor:none;transition:background .2s}
#mobcls:hover{background:var(--gld)}
#mobcls svg{width:15px;height:15px;stroke:var(--wht);fill:none;stroke-width:2}
#mobcls:hover svg{stroke:var(--blk)}

/* NAV */
nav{position:sticky;top:0;z-index:1000;display:flex;align-items:center;gap:24px;padding:14px 52px;background:rgba(6,5,4,.96);backdrop-filter:blur(32px);border-bottom:1px solid var(--bdr)}
.nl{text-decoration:none;flex-shrink:0;display:flex;flex-direction:column;line-height:1.15}
.nl-top{font-family:"Bebas Neue",sans-serif;font-size:21px;letter-spacing:8px;color:var(--wht);display:flex;align-items:baseline;gap:4px}
.nl-top span{color:var(--gld)}
.nl-btm{font-family:"Cormorant Garamond",serif;font-size:8px;letter-spacing:6px;color:var(--gld);opacity:.55;font-style:italic}
.nsrch{flex:1;max-width:280px;position:relative}
.nsrch input{width:100%;background:rgba(255,255,255,.03);border:1px solid var(--bdr);padding:9px 14px 9px 36px;font-family:"Space Mono",monospace;font-size:9px;letter-spacing:1.5px;color:var(--wht);outline:none;transition:border-color .3s}
.nsrch input:focus{border-color:rgba(184,150,62,.3)}
.nsrch input::placeholder{color:rgba(255,255,255,.15)}
.nsrch svg{position:absolute;left:11px;top:50%;transform:translateY(-50%);width:13px;height:13px;stroke:rgba(184,150,62,.35);fill:none;stroke-width:2}
.nlinks{display:flex;gap:24px;list-style:none;margin-left:6px}
.nlinks a{font-family:"Barlow Condensed",sans-serif;font-size:12px;font-weight:500;letter-spacing:3px;text-transform:uppercase;color:var(--wht);text-decoration:none;opacity:.38;transition:opacity .2s}
.nlinks a:hover{opacity:1}
.nr{display:flex;align-items:center;gap:10px;margin-left:auto;flex-shrink:0}
.nibtn{background:none;border:none;cursor:none;padding:7px 10px;display:flex;align-items:center;gap:6px;font-family:"Barlow Condensed",sans-serif;font-size:11px;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.42);position:relative;transition:color .2s}
.nibtn:hover{color:var(--wht)}
.nibtn svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:1.6}
.nbdg{position:absolute;top:-4px;right:-3px;min-width:16px;height:16px;background:var(--gld);border-radius:50%;font-family:"Space Mono",monospace;font-size:7.5px;color:var(--blk);display:flex;align-items:center;justify-content:center;padding:0 3px;opacity:0;transform:scale(0);transition:opacity .2s,transform .25s cubic-bezier(.34,1.56,.64,1)}
.nbdg.on{opacity:1;transform:scale(1)}
.nwa{display:flex;align-items:center;gap:8px;padding:9px 18px;background:#25D366;border:none;font-family:"Barlow Condensed",sans-serif;font-size:12px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--wht);text-decoration:none;cursor:none;transition:background .3s;flex-shrink:0}
.nwa:hover{background:#1db954}
.nwa svg{width:14px;height:14px;fill:var(--wht)}
.hbg{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:none;padding:4px}
.hbg span{display:block;width:20px;height:1px;background:var(--wht)}

/* ===================== HERO ===================== */
#hero{position:relative;height:100vh;min-height:680px;overflow:hidden;display:flex;align-items:center;justify-content:center}
.h-slides{position:absolute;inset:0;z-index:0}
.hs{position:absolute;inset:0;background-size:cover;background-position:center;opacity:0;animation:hslide 24s infinite}
.hs:nth-child(1){animation-delay:0s}
.hs:nth-child(2){animation-delay:8s}
.hs:nth-child(3){animation-delay:16s}
@keyframes hslide{0%{opacity:0;transform:scale(1.07)}6%{opacity:1}30%{opacity:1;transform:scale(1)}36%{opacity:0}100%{opacity:0;transform:scale(1.07)}}
.h-ovl{position:absolute;inset:0;z-index:1;background:linear-gradient(to bottom,rgba(6,5,4,.65) 0%,rgba(6,5,4,.2) 38%,rgba(6,5,4,.28) 60%,rgba(6,5,4,.92) 100%)}
.h-cnt{position:relative;z-index:2;text-align:center;padding:0 24px;max-width:860px}
.h-lbl{font-family:"Cormorant Garamond",serif;font-size:13px;font-style:italic;letter-spacing:6px;color:var(--cream);opacity:0;transform:translateY(12px);transition:opacity .8s .4s,transform .8s .4s;margin-bottom:18px;display:flex;align-items:center;justify-content:center;gap:16px}
.h-lbl::before,.h-lbl::after{content:"";width:32px;height:1px;background:var(--gld);opacity:.5}
.h-lbl.v{opacity:1;transform:none}
.h-ttl{font-family:"Bebas Neue",sans-serif;font-size:clamp(82px,12vw,160px);line-height:.82;color:var(--wht);overflow:hidden;margin-bottom:6px}
.htl{display:block;transform:translateY(115%);transition:transform .9s cubic-bezier(.77,0,.175,1)}
.htl.v{transform:none}
.htl:nth-child(1){transition-delay:.1s}
.htl:nth-child(2){transition-delay:.24s}
.h-em{font-family:"Cormorant Garamond",serif;font-size:clamp(78px,11vw,148px);font-style:italic;font-weight:300;color:var(--gld);letter-spacing:4px;display:block;transform:translateY(115%);transition:transform .9s cubic-bezier(.77,0,.175,1) .36s}
.h-em.v{transform:none}
.h-sub{font-family:"Cormorant Garamond",serif;font-size:18px;font-style:italic;letter-spacing:3px;color:var(--cream);opacity:.7;margin-top:20px;opacity:0;transition:opacity .7s 1.1s}
.h-sub.v{opacity:.7}
.h-search{margin-top:36px;opacity:0;transform:translateY(14px);transition:opacity .6s 1.25s,transform .6s 1.25s}
.h-search.v{opacity:1;transform:none}
.h-sinput{display:flex;max-width:540px;margin:0 auto;background:rgba(6,5,4,.7);backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,.09)}
.h-sinput input{flex:1;background:none;border:none;padding:16px 20px;font-family:"Barlow Condensed",sans-serif;font-size:14px;letter-spacing:1.5px;color:var(--wht);outline:none}
.h-sinput input::placeholder{color:rgba(255,255,255,.28)}
.h-sinput button{padding:16px 24px;background:var(--gld);border:none;font-family:"Bebas Neue",sans-serif;font-size:16px;letter-spacing:4px;color:var(--blk);cursor:none;transition:background .3s;flex-shrink:0;position:relative;overflow:hidden}
.h-sinput button::after{content:"";position:absolute;top:-50%;left:-75%;width:50%;height:200%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.2),transparent);transform:skewX(-20deg);transition:left .5s}
.h-sinput button:hover{background:var(--gld2)}
.h-sinput button:hover::after{left:140%}
.h-quick{display:flex;gap:8px;justify-content:center;margin-top:12px;flex-wrap:wrap}
.h-quick span{font-family:"Space Mono",monospace;font-size:8px;letter-spacing:3px;color:rgba(255,255,255,.38);padding:5px 12px;border:1px solid rgba(255,255,255,.08);cursor:none;transition:color .2s,border-color .2s;text-transform:uppercase}
.h-quick span:hover{color:var(--gld);border-color:rgba(184,150,62,.3)}
.h-strip{position:absolute;bottom:0;left:0;right:0;z-index:2;display:flex;border-top:1px solid rgba(255,255,255,.06);background:rgba(6,5,4,.7);backdrop-filter:blur(12px)}
.h-strip-item{flex:1;padding:18px 32px;border-right:1px solid rgba(255,255,255,.06);text-align:center}
.h-strip-item:last-child{border-right:none}
.h-sn{font-family:"Bebas Neue",sans-serif;font-size:34px;color:var(--gld);line-height:1}
.h-sl{font-family:"Space Mono",monospace;font-size:7px;letter-spacing:3.5px;color:var(--plat);margin-top:3px;text-transform:uppercase}
.h-scroll{position:absolute;right:40px;top:50%;transform:translateY(-50%);z-index:3;display:flex;flex-direction:column;align-items:center;gap:10px;opacity:0;animation:ldup .6s ease-out 1.8s forwards}
.h-scroll span{font-family:"Space Mono",monospace;font-size:7px;letter-spacing:5px;color:rgba(255,255,255,.3);writing-mode:vertical-rl}
.h-scroll-line{width:1px;height:60px;background:linear-gradient(to bottom,rgba(184,150,62,.4),transparent);animation:scrollln 1.8s ease-in-out infinite}
@keyframes scrollln{0%,100%{transform:scaleY(1);transform-origin:top}50%{transform:scaleY(.4);transform-origin:top}}
.h-dots{position:absolute;bottom:72px;left:50%;transform:translateX(-50%);z-index:3;display:flex;gap:8px}
.h-dot{width:20px;height:1px;background:rgba(255,255,255,.2);transition:background .4s,width .4s;cursor:none}
.h-dot.on{background:var(--gld);width:36px}

/* TRUST STRIP */
#trust{background:var(--dark);border-top:1px solid var(--bdr);border-bottom:1px solid var(--bdr);padding:22px 52px;display:flex;align-items:center;gap:48px;overflow:hidden}
.tr-lbl{font-family:"Space Mono",monospace;font-size:7px;letter-spacing:5px;color:var(--gld);white-space:nowrap;opacity:.65;text-transform:uppercase;flex-shrink:0}
.tr-logos{display:flex;gap:0;overflow:hidden;flex:1}
.tr-in{display:inline-flex;animation:mq 32s linear infinite;gap:0;white-space:nowrap}
.tr-in span{font-family:"Bebas Neue",sans-serif;font-size:13px;letter-spacing:6px;color:rgba(255,255,255,.25);padding:0 28px;border-right:1px solid var(--bdr);transition:color .2s}
.tr-in span:hover{color:rgba(255,255,255,.55)}

/* FEATURED PROPERTY */
#featured{position:relative;min-height:600px;display:grid;grid-template-columns:1.1fr 1fr;overflow:hidden;background:var(--warm)}
.feat-img{position:relative;overflow:hidden}
.feat-img img{width:100%;height:100%;object-fit:cover;filter:brightness(.55);transition:transform 8s ease}
#featured:hover .feat-img img{transform:scale(1.03)}
.feat-img-ovl{position:absolute;inset:0;background:linear-gradient(to right,transparent 55%,var(--warm) 100%)}
.feat-body{padding:64px 56px;display:flex;flex-direction:column;justify-content:center;position:relative;z-index:1}
.feat-eyebrow{display:flex;align-items:center;gap:12px;margin-bottom:20px}
.feat-badge{font-family:"Space Mono",monospace;font-size:8px;letter-spacing:5px;color:var(--blk);background:var(--gld);padding:5px 12px;text-transform:uppercase}
.feat-city{font-family:"Space Mono",monospace;font-size:8px;letter-spacing:4px;color:var(--plat);text-transform:uppercase}
.feat-name{font-family:"Cormorant Garamond",serif;font-size:clamp(36px,4vw,52px);font-weight:300;color:var(--wht);line-height:1.08;margin-bottom:8px}
.feat-price{font-family:"Bebas Neue",sans-serif;font-size:36px;letter-spacing:3px;color:var(--gld);margin-bottom:6px}
.feat-loc{font-family:"Space Mono",monospace;font-size:9px;letter-spacing:3px;color:var(--plat);margin-bottom:22px;display:flex;align-items:center;gap:6px}
.feat-loc svg{width:10px;height:10px;stroke:var(--gld);fill:none;stroke-width:2}
.feat-meta{display:flex;gap:20px;padding:18px 0;border-top:1px solid var(--bdr);border-bottom:1px solid var(--bdr);margin-bottom:22px}
.feat-mi{font-family:"Space Mono",monospace;font-size:8px;letter-spacing:2px;color:var(--plat);display:flex;align-items:center;gap:6px;text-transform:uppercase}
.feat-mi svg{width:12px;height:12px;stroke:var(--gld);fill:none;stroke-width:1.7}
.feat-desc{font-family:"Cormorant Garamond",serif;font-size:16px;font-style:italic;font-weight:300;color:var(--plat);line-height:1.8;margin-bottom:28px}
.feat-btns{display:flex;gap:12px}
.btn-gold{display:inline-flex;align-items:center;gap:10px;padding:14px 32px;background:var(--gld);font-family:"Bebas Neue",sans-serif;font-size:18px;letter-spacing:4px;color:var(--blk);border:none;cursor:none;position:relative;overflow:hidden;transition:background .3s;text-decoration:none}
.btn-gold::after{content:"";position:absolute;top:-50%;left:-80%;width:50%;height:200%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.22),transparent);transform:skewX(-20deg);transition:left .5s}
.btn-gold:hover{background:var(--gld2)}
.btn-gold:hover::after{left:140%}
.btn-gold svg{width:16px;height:16px;stroke:var(--blk);fill:none;stroke-width:2}
.btn-outline{display:inline-flex;align-items:center;gap:10px;padding:13px 30px;background:none;border:1px solid rgba(255,255,255,.15);font-family:"Bebas Neue",sans-serif;font-size:18px;letter-spacing:4px;color:var(--wht);cursor:none;transition:border-color .3s,color .3s;text-decoration:none}
.btn-outline:hover{border-color:var(--gld);color:var(--gld)}

/* MARQUEE BANDS */
.mb{overflow:hidden;padding:10px 0;white-space:nowrap}
.mb.g{background:var(--gld)}.mb.d{background:var(--dark)}.mb.m{background:var(--mid)}
.mi{display:inline-flex;animation:mq 32s linear infinite}
.mi.rv{animation-direction:reverse}
.mb.g .mi span{font-family:"Bebas Neue",sans-serif;font-size:13px;letter-spacing:7px;padding:0 22px;color:var(--blk)}
.mb.d .mi span,.mb.m .mi span{font-family:"Bebas Neue",sans-serif;font-size:13px;letter-spacing:7px;padding:0 22px;color:rgba(255,255,255,.18)}
.mb.m .mi span{color:rgba(184,150,62,.35)}

/* CATEGORIES */
#cats{padding:80px 52px 0}
.sec-lbl{font-family:"Cormorant Garamond",serif;font-size:12px;font-style:italic;letter-spacing:6px;color:var(--gld);margin-bottom:10px;display:flex;align-items:center;gap:14px}
.sec-lbl::before{content:"";width:22px;height:1px;background:var(--gld)}
.sec-ttl{font-family:"Bebas Neue",sans-serif;font-size:clamp(38px,5vw,58px);color:var(--wht);margin-bottom:32px;line-height:.92}
.cat-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:2px}
.ccat{position:relative;overflow:hidden;aspect-ratio:2/3;cursor:none}
.ccat img{width:100%;height:100%;object-fit:cover;transition:transform .65s cubic-bezier(.25,.46,.45,.94),filter .5s;filter:brightness(.35)}
.ccat:hover img,.ccat.ac img{transform:scale(1.08);filter:brightness(.6)}
.ccat-body{position:absolute;inset:0;display:flex;flex-direction:column;justify-content:flex-end;padding:20px 16px;background:linear-gradient(to top,rgba(6,5,4,.95) 0%,transparent 60%);z-index:2}
.ccat-body h3{font-family:"Cormorant Garamond",serif;font-size:20px;font-weight:400;color:var(--wht);margin-bottom:2px}
.ccat-body p{font-family:"Space Mono",monospace;font-size:7.5px;letter-spacing:3px;color:var(--gld);opacity:.75}
.ccat-bar{position:absolute;bottom:0;left:0;width:0%;height:2px;background:var(--gld);z-index:3;transition:width .4s cubic-bezier(.25,.46,.45,.94)}
.ccat:hover .ccat-bar,.ccat.ac .ccat-bar{width:100%}

/* ===================== SHOP — SPLIT CARDS ===================== */
#shop{padding:80px 52px 100px}
.shdr{display:flex;flex-wrap:wrap;align-items:flex-end;justify-content:space-between;gap:20px;margin-bottom:30px}
.sttl{font-family:"Bebas Neue",sans-serif;font-size:clamp(36px,5vw,68px);line-height:.88;color:var(--wht)}
.sh-r{display:flex;align-items:center;gap:14px;flex-wrap:wrap}
#rsc{font-family:"Space Mono",monospace;font-size:8px;letter-spacing:3px;color:var(--plat)}
.prf{display:flex;align-items:center;gap:8px}
.prf label{font-family:"Space Mono",monospace;font-size:7.5px;letter-spacing:2px;color:var(--plat)}
#pslide{width:88px;accent-color:var(--gld);cursor:none}
#pval{font-family:"Space Mono",monospace;font-size:8px;letter-spacing:1px;color:var(--wht);min-width:88px;text-align:right}
.srt-sel{background:var(--dark);border:1px solid var(--bdr);padding:9px 12px;font-family:"Space Mono",monospace;font-size:8px;letter-spacing:1.5px;color:var(--wht);outline:none;cursor:none;appearance:none;min-width:158px}
.srt-sel option{background:var(--mid)}
.tabs{display:flex;overflow-x:auto;border-bottom:1px solid var(--bdr);margin-bottom:40px;scrollbar-width:none}
.tabs::-webkit-scrollbar{display:none}
.tab{background:none;border:none;padding:12px 20px;font-family:"Barlow Condensed",sans-serif;font-size:12px;font-weight:700;letter-spacing:3.5px;text-transform:uppercase;color:rgba(255,255,255,.27);cursor:none;white-space:nowrap;border-bottom:2px solid transparent;margin-bottom:-1px;transition:color .25s,border-color .25s}
.tab.on{color:var(--gld);border-bottom-color:var(--gld)}
.tab:hover:not(.on){color:rgba(255,255,255,.55)}

/* SPLIT CARD */
.pgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px}
.pc{background:var(--dark);border:1px solid var(--bdr);overflow:hidden;cursor:none;display:flex;flex-direction:column;transition:border-color .35s,box-shadow .35s,transform .35s}
.pc:hover{border-color:var(--gbdr);box-shadow:0 16px 56px rgba(0,0,0,.5);transform:translateY(-5px)}
.pc-img{position:relative;overflow:hidden;aspect-ratio:16/10}
.pc-img img{width:100%;height:100%;object-fit:cover;filter:brightness(.82);transition:transform .7s cubic-bezier(.25,.46,.45,.94),filter .4s}
.pc:hover .pc-img img{transform:scale(1.07);filter:brightness(.95)}
.pc-bdg-row{position:absolute;top:13px;left:13px;right:13px;display:flex;justify-content:space-between;align-items:flex-start;z-index:3}
.cbdg{padding:4px 11px;font-family:"Barlow Condensed",sans-serif;font-size:10px;font-weight:700;letter-spacing:3px;text-transform:uppercase}
.bp{background:var(--gld);color:var(--blk)}.be{background:#8a6b28;color:var(--wht)}.bn{background:var(--wht);color:var(--blk)}.bh{background:#c0392b;color:var(--wht)}.br{background:#2471a3;color:var(--wht)}.bc{background:#1a7878;color:var(--wht)}.bm{background:#27ae60;color:var(--wht)}.bu{background:rgba(6,5,4,.92);color:var(--gld);border:1px solid var(--gld)}
.pc-acts{display:flex;gap:7px;opacity:0;transform:translateX(6px);transition:opacity .3s,transform .3s}
.pc:hover .pc-acts{opacity:1;transform:none}
.abtn{width:32px;height:32px;border-radius:50%;background:rgba(6,5,4,.82);border:1px solid rgba(255,255,255,.08);display:flex;align-items:center;justify-content:center;cursor:none;backdrop-filter:blur(8px);transition:background .2s,border-color .2s}
.abtn:hover,.abtn.won{background:var(--gld);border-color:var(--gld)}
.abtn svg{width:12px;height:12px;stroke:var(--wht);fill:none;stroke-width:1.8}
.abtn:hover svg,.abtn.won svg{stroke:var(--blk)}
.abtn.won svg{fill:var(--blk)}
.pc-status{position:absolute;bottom:12px;right:12px;z-index:3;font-family:"Space Mono",monospace;font-size:7px;letter-spacing:3px;padding:4px 9px;background:rgba(6,5,4,.85);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,.06);color:var(--wht);text-transform:uppercase}
.pc-body{padding:20px 20px 18px;background:var(--dark);display:flex;flex-direction:column;gap:7px;border-top:1px solid var(--bdr);flex:1}
.pc-type{font-family:"Space Mono",monospace;font-size:7.5px;letter-spacing:4px;color:var(--gld);text-transform:uppercase}
.pc-name{font-family:"Cormorant Garamond",serif;font-size:21px;font-weight:600;letter-spacing:.5px;color:var(--wht);line-height:1.1}
.pc-price{font-family:"Space Mono",monospace;font-size:12px;letter-spacing:1.5px;color:var(--gld);font-weight:700}
.pc-loc{font-family:"Barlow Condensed",sans-serif;font-size:12px;font-weight:300;letter-spacing:1.5px;color:var(--plat);display:flex;align-items:center;gap:5px}
.pc-loc svg{width:9px;height:9px;stroke:var(--gld);fill:none;stroke-width:2;flex-shrink:0}
.pc-meta{display:flex;gap:14px;padding-top:10px;border-top:1px solid var(--bdr);flex-wrap:wrap;margin-top:2px}
.pc-mi{font-family:"Space Mono",monospace;font-size:7.5px;letter-spacing:1px;color:var(--plat);display:flex;align-items:center;gap:4px}
.pc-mi svg{width:10px;height:10px;stroke:rgba(184,150,62,.5);fill:none;stroke-width:2}
.pc-inq{width:100%;padding:11px;background:var(--mid);border:1px solid rgba(255,255,255,.05);font-family:"Bebas Neue",sans-serif;font-size:14px;letter-spacing:3px;color:rgba(255,255,255,.55);cursor:none;transition:background .25s,border-color .25s,color .25s;text-align:center;margin-top:6px;position:relative;overflow:hidden}
.pc-inq::after{content:"";position:absolute;top:-50%;left:-80%;width:50%;height:200%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.08),transparent);transform:skewX(-20deg);transition:left .5s}
.pc-inq:hover{background:var(--gld);border-color:var(--gld);color:var(--blk)}
.pc-inq:hover::after{left:140%}
.no-res{grid-column:1/-1;padding:80px 0;text-align:center}
.no-res p{font-family:"Space Mono",monospace;font-size:9px;letter-spacing:5px;color:var(--plat)}

/* STATS — FULL BLEED */
#stats{position:relative;overflow:hidden}
.stats-bg{position:absolute;inset:0;z-index:0}
.stats-bg img{width:100%;height:100%;object-fit:cover;filter:brightness(.12)}
.stats-bg::after{content:"";position:absolute;inset:0;background:rgba(6,5,4,.6)}
.stats-inner{position:relative;z-index:1;display:grid;grid-template-columns:repeat(4,1fr);border-top:1px solid rgba(255,255,255,.06);border-bottom:1px solid rgba(255,255,255,.06)}
.stt{padding:52px 36px;border-right:1px solid rgba(255,255,255,.06);text-align:center;position:relative}
.stt:last-child{border-right:none}
.stt::before{content:"";position:absolute;inset:0;background:radial-gradient(circle at center,rgba(184,150,62,.06) 0%,transparent 70%);opacity:0;transition:opacity .4s}
.stt:hover::before{opacity:1}
.stn{font-family:"Bebas Neue",sans-serif;font-size:clamp(54px,6vw,82px);color:var(--gld);line-height:1}
.stl{font-family:"Space Mono",monospace;font-size:7.5px;letter-spacing:4px;color:var(--plat);margin-top:6px;text-transform:uppercase}

/* FEATURES */
#features{display:grid;grid-template-columns:1fr 1fr;background:var(--mid)}
.fimg{overflow:hidden;position:relative;min-height:560px}
.fimg img{width:100%;height:100%;object-fit:cover;filter:brightness(.5);transition:transform 8s ease}
.fimg:hover img{transform:scale(1.04)}
.fimg-ovl{position:absolute;inset:0;background:linear-gradient(to right,transparent 50%,var(--mid) 100%)}
.ftxt{padding:72px 56px;display:flex;flex-direction:column;justify-content:center}
.fttl{font-family:"Bebas Neue",sans-serif;font-size:clamp(38px,4.5vw,60px);line-height:.9;color:var(--wht);margin-bottom:10px}
.fttl-serif{font-family:"Cormorant Garamond",serif;font-size:clamp(22px,2.5vw,32px);font-style:italic;font-weight:300;color:var(--gld);margin-bottom:36px;display:block}
.fitms{display:flex;flex-direction:column;gap:24px}
.fitm{display:flex;gap:18px;align-items:flex-start}
.fic{width:40px;height:40px;border:1px solid var(--bdr);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:border-color .3s}
.fic svg{width:17px;height:17px;stroke:var(--gld);fill:none;stroke-width:1.6}
.fitm:hover .fic{border-color:rgba(184,150,62,.35)}
.fin{font-family:"Bebas Neue",sans-serif;font-size:18px;letter-spacing:2px;color:var(--wht);margin-bottom:3px}
.fid{font-family:"Barlow Condensed",sans-serif;font-size:13.5px;font-weight:300;letter-spacing:.7px;color:var(--plat);line-height:1.65}

/* CEO — MAGAZINE STYLE */
#ceo{background:var(--warm);overflow:hidden;position:relative}
.ceo-top{padding:64px 52px 0;display:flex;align-items:center;gap:8px;border-bottom:none}
.ceo-top .sec-lbl{margin-bottom:0}
.ceo-grid{display:grid;grid-template-columns:1fr 1.4fr;min-height:560px}
.ceo-photo{position:relative;overflow:hidden}
.ceo-photo img{width:100%;height:100%;object-fit:cover;object-position:top center;filter:grayscale(20%) brightness(.85);transition:transform 8s ease}
#ceo:hover .ceo-photo img{transform:scale(1.03)}
.ceo-photo-ovl{position:absolute;inset:0;background:linear-gradient(to right,transparent 50%,var(--warm) 100%)}
.ceo-body{padding:60px 64px 60px 40px;display:flex;flex-direction:column;justify-content:center;position:relative}
.ceo-quote{position:absolute;top:40px;right:52px;font-family:"Cormorant Garamond",serif;font-size:200px;color:rgba(184,150,62,.06);line-height:1;pointer-events:none;font-style:italic}
.ceo-pullquote{font-family:"Cormorant Garamond",serif;font-size:clamp(20px,2.5vw,28px);font-style:italic;font-weight:300;color:var(--wht);line-height:1.6;margin-bottom:32px;position:relative;z-index:1;border-left:2px solid var(--gld);padding-left:22px}
.ceo-name{font-family:"Bebas Neue",sans-serif;font-size:clamp(38px,4vw,52px);letter-spacing:3px;color:var(--wht);line-height:1}
.ceo-title{font-family:"Space Mono",monospace;font-size:8px;letter-spacing:4px;color:var(--gld);opacity:.7;margin-top:4px;margin-bottom:22px;text-transform:uppercase}
.ceo-bio{font-family:"Cormorant Garamond",serif;font-size:16px;font-weight:300;color:var(--plat);line-height:1.85;margin-bottom:28px}
.ceo-sig{font-family:"Space Mono",monospace;font-size:8.5px;letter-spacing:3px;color:var(--wht);border-top:1px solid var(--bdr);padding-top:16px}
.ceo-sig span{color:var(--gld)}
.ceo-stats{display:flex;gap:28px;margin-top:22px;padding-top:20px;border-top:1px solid var(--bdr)}
.cs-n{font-family:"Bebas Neue",sans-serif;font-size:28px;color:var(--gld);line-height:1}
.cs-l{font-family:"Space Mono",monospace;font-size:7px;letter-spacing:3px;color:var(--plat);margin-top:2px;text-transform:uppercase}

/* REVIEWS */
#reviews{padding:80px 52px;background:var(--blk)}
.rv-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;margin-top:40px}
.rv{background:var(--dark);border:1px solid var(--bdr);padding:32px 26px;position:relative;overflow:hidden;transition:border-color .3s}
.rv:hover{border-color:var(--gbdr)}
.rv::before{content:"";position:absolute;bottom:0;left:0;width:0%;height:1px;background:var(--gld);transition:width .4s}
.rv:hover::before{width:100%}
.rv-stars{display:flex;gap:3px;margin-bottom:16px}
.rv-stars span{color:var(--gld);font-size:12px}
.rv-q{font-family:"Cormorant Garamond",serif;font-size:16px;font-style:italic;font-weight:300;letter-spacing:.3px;color:rgba(237,232,223,.6);line-height:1.8;margin-bottom:22px}
.rv-auth{border-top:1px solid var(--bdr);padding-top:16px}
.rv-name{font-family:"Space Mono",monospace;font-size:8px;letter-spacing:3px;color:var(--wht);text-transform:uppercase}
.rv-det{font-family:"Cormorant Garamond",serif;font-size:13px;font-style:italic;color:var(--gld);margin-top:4px}

/* CTA */
#cta{padding:100px 52px;background:var(--mid);position:relative;overflow:hidden;text-align:center}
.cta-bg{position:absolute;inset:-5%;background:radial-gradient(ellipse at 50% 60%,rgba(184,150,62,.06) 0%,transparent 58%);pointer-events:none}
.cta-i{position:relative;z-index:1}
.cta-serif{font-family:"Cormorant Garamond",serif;font-size:14px;font-style:italic;letter-spacing:6px;color:var(--gld);opacity:.75;margin-bottom:12px}
.cta-ttl{font-family:"Bebas Neue",sans-serif;font-size:clamp(52px,7vw,96px);line-height:.85;color:var(--wht);margin-bottom:14px}
.cta-sub{font-family:"Space Mono",monospace;font-size:8px;letter-spacing:5px;color:var(--plat);margin-bottom:40px}
.cta-form{display:flex;gap:0;max-width:480px;margin:0 auto;border:1px solid var(--bdr)}
.cta-form input{flex:1;background:rgba(255,255,255,.02);border:none;padding:15px 18px;font-family:"Space Mono",monospace;font-size:9px;letter-spacing:1.5px;color:var(--wht);outline:none}
.cta-form input::placeholder{color:rgba(255,255,255,.15)}
.cta-form button{padding:15px 24px;background:var(--gld);border:none;font-family:"Bebas Neue",sans-serif;font-size:16px;letter-spacing:3px;color:var(--blk);cursor:none;transition:background .3s;flex-shrink:0;position:relative;overflow:hidden}
.cta-form button::after{content:"";position:absolute;top:-50%;left:-80%;width:50%;height:200%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.2),transparent);transform:skewX(-20deg);transition:left .5s}
.cta-form button:hover{background:var(--gld2)}
.cta-form button:hover::after{left:140%}

/* FOOTER */
footer{padding:64px 52px 36px;background:var(--blk);border-top:1px solid var(--bdr)}
.ft-top{display:grid;grid-template-columns:2.2fr 1fr 1fr 1fr;gap:52px;margin-bottom:52px}
.ft-brand{font-family:"Bebas Neue",sans-serif;font-size:32px;letter-spacing:8px;color:var(--wht)}
.ft-brand span{color:var(--gld)}
.ft-grp{font-family:"Cormorant Garamond",serif;font-size:9px;font-style:italic;letter-spacing:6px;color:var(--gld);opacity:.5;margin-top:2px}
.ft-tag{font-family:"Cormorant Garamond",serif;font-size:15px;font-style:italic;font-weight:300;letter-spacing:.5px;color:var(--plat);margin-top:12px;line-height:1.85;max-width:280px}
.ft-adr{font-family:"Space Mono",monospace;font-size:8px;letter-spacing:2px;color:var(--plat);margin-top:16px;line-height:2}
.ft-adr span{color:var(--gld)}
.ft-wa{display:inline-flex;align-items:center;gap:8px;margin-top:18px;padding:10px 20px;background:#25D366;font-family:"Barlow Condensed",sans-serif;font-size:12px;font-weight:700;letter-spacing:3px;color:var(--wht);text-decoration:none;transition:background .3s}
.ft-wa:hover{background:#1db954}
.ft-wa svg{width:14px;height:14px;fill:var(--wht)}
.ft-col h4{font-family:"Space Mono",monospace;font-size:7.5px;letter-spacing:5px;text-transform:uppercase;color:var(--gld);margin-bottom:18px;opacity:.7}
.ft-col ul{list-style:none;display:flex;flex-direction:column;gap:10px}
.ft-col li a{font-family:"Cormorant Garamond",serif;font-size:14px;font-weight:300;letter-spacing:.5px;color:var(--plat);text-decoration:none;transition:color .2s}
.ft-col li a:hover{color:var(--wht)}
.ft-bot{display:flex;justify-content:space-between;align-items:center;padding-top:24px;border-top:1px solid var(--bdr);flex-wrap:wrap;gap:12px}
.ft-copy{font-family:"Space Mono",monospace;font-size:7px;letter-spacing:3px;color:rgba(255,255,255,.14)}
.ft-soc{display:flex;gap:22px}
.ft-soc a{font-family:"Barlow Condensed",sans-serif;font-size:11px;letter-spacing:3px;color:var(--plat);text-decoration:none;text-transform:uppercase;transition:color .2s}
.ft-soc a:hover{color:var(--gld)}

/* PROPERTY MODAL */
#pmod{position:fixed;inset:0;z-index:8000;display:none;align-items:center;justify-content:center;background:rgba(5,4,3,.94);backdrop-filter:blur(18px)}
#pmod.open{display:flex}
.pm{background:var(--mid);width:92%;max-width:1000px;max-height:92vh;overflow-y:auto;display:grid;grid-template-columns:1.1fr 1fr;position:relative;scrollbar-width:thin;scrollbar-color:var(--gld) transparent}
.pm::-webkit-scrollbar{width:2px}
.pm::-webkit-scrollbar-thumb{background:var(--gld)}
.pm-l{min-height:440px}
.pm-main{width:100%;height:340px;object-fit:cover;display:block}
.pm-thumbs{display:flex;gap:2px;padding:2px}
.pm-th{flex:1;height:65px;object-fit:cover;cursor:none;opacity:.45;transition:opacity .2s,filter .2s;filter:brightness(.7)}
.pm-th:hover,.pm-th.ac{opacity:1;filter:brightness(1)}
.pm-r{padding:34px 30px;display:flex;flex-direction:column;justify-content:space-between;gap:14px}
.pm-cls{position:absolute;top:14px;right:14px;z-index:10;width:34px;height:34px;background:rgba(5,4,3,.88);border:1px solid var(--bdr);display:flex;align-items:center;justify-content:center;cursor:none;transition:background .2s}
.pm-cls:hover{background:var(--gld)}
.pm-cls svg{width:14px;height:14px;stroke:var(--wht);fill:none;stroke-width:2}
.pm-cls:hover svg{stroke:var(--blk)}
.pm-bdg-row{display:flex;align-items:center;gap:10px;margin-bottom:8px}
.pm-type{font-family:"Space Mono",monospace;font-size:7px;letter-spacing:4px;color:var(--gld)}
.pm-name{font-family:"Cormorant Garamond",serif;font-size:clamp(26px,3vw,34px);font-weight:400;color:var(--wht);line-height:1.05;margin-bottom:4px}
.pm-price{font-family:"Bebas Neue",sans-serif;font-size:28px;letter-spacing:3px;color:var(--gld);margin-bottom:5px}
.pm-loc{font-family:"Space Mono",monospace;font-size:8px;letter-spacing:2px;color:var(--plat);display:flex;align-items:center;gap:6px;margin-bottom:16px}
.pm-loc svg{width:10px;height:10px;stroke:var(--gld);fill:none;stroke-width:2}
.pm-facts{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;margin-bottom:16px}
.pm-fact{background:var(--dark);border:1px solid var(--bdr);padding:12px 10px;text-align:center}
.pm-fv{font-family:"Bebas Neue",sans-serif;font-size:19px;letter-spacing:1px;color:var(--wht)}
.pm-fl{font-family:"Space Mono",monospace;font-size:6.5px;letter-spacing:2.5px;color:var(--plat);margin-top:2px;text-transform:uppercase}
.pm-divider{height:1px;background:var(--bdr);margin:12px 0}
.pm-desc{font-family:"Cormorant Garamond",serif;font-size:15px;font-style:italic;font-weight:300;color:var(--plat);line-height:1.8;margin-bottom:16px}
.pm-btns{display:flex;flex-direction:column;gap:8px}
.pm-inq{width:100%;padding:13px;background:var(--gld);border:none;font-family:"Bebas Neue",sans-serif;font-size:16px;letter-spacing:3px;color:var(--blk);cursor:none;transition:background .3s;position:relative;overflow:hidden}
.pm-inq::after{content:"";position:absolute;top:-50%;left:-80%;width:50%;height:200%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.2),transparent);transform:skewX(-20deg);transition:left .5s}
.pm-inq:hover{background:var(--gld2)}
.pm-inq:hover::after{left:140%}
.pm-wabtn{width:100%;padding:12px;background:#25D366;border:none;font-family:"Bebas Neue",sans-serif;font-size:16px;letter-spacing:3px;color:var(--wht);cursor:none;transition:background .3s;display:flex;align-items:center;justify-content:center;gap:10px}
.pm-wabtn:hover{background:#1db954}
.pm-wabtn svg{width:16px;height:16px;fill:var(--wht)}

/* SIDEBARS */
.sidebar{position:fixed;top:0;right:0;height:100vh;background:var(--mid);z-index:5000;transform:translateX(100%);transition:transform .42s cubic-bezier(.77,0,.175,1);display:flex;flex-direction:column;border-left:1px solid var(--bdr)}
#wlsb{width:400px;max-width:90vw}
#iqsb{width:420px;max-width:90vw}
.sidebar.open{transform:none}
.sb-hd{padding:22px 26px;border-bottom:1px solid var(--bdr);display:flex;justify-content:space-between;align-items:center}
.sb-hd h2{font-family:"Cormorant Garamond",serif;font-size:22px;font-weight:400;color:var(--wht)}
.sb-hd h2 em{color:var(--gld);font-style:italic}
.sb-cls{background:none;border:1px solid var(--bdr);width:30px;height:30px;display:flex;align-items:center;justify-content:center;cursor:none;transition:background .2s}
.sb-cls:hover{background:var(--gld)}
.sb-cls svg{width:13px;height:13px;stroke:var(--wht);fill:none;stroke-width:2}
.sb-cls:hover svg{stroke:var(--blk)}
.sb-body{flex:1;overflow-y:auto;padding:16px 22px;scrollbar-width:thin;scrollbar-color:var(--gld) transparent}
.sb-body::-webkit-scrollbar{width:2px}
.sb-body::-webkit-scrollbar-thumb{background:var(--gld)}
.sb-empty{display:flex;flex-direction:column;align-items:center;justify-content:center;height:260px;gap:14px}
.sb-empty svg{width:40px;height:40px;stroke:rgba(184,150,62,.18);fill:none;stroke-width:1}
.sb-empty p{font-family:"Space Mono",monospace;font-size:8px;letter-spacing:4px;color:var(--plat);text-align:center}
.wl-item,.iq-item{display:flex;gap:12px;padding:14px 0;border-bottom:1px solid var(--bdr);align-items:flex-start}
.wl-item:last-child,.iq-item:last-child{border-bottom:none}
.sb-thumb{width:76px;height:55px;overflow:hidden;flex-shrink:0}
.sb-thumb img{width:100%;height:100%;object-fit:cover;filter:brightness(.75)}
.sb-nm{font-family:"Cormorant Garamond",serif;font-size:17px;font-weight:400;color:var(--wht);line-height:1.1}
.sb-loc{font-family:"Space Mono",monospace;font-size:7.5px;letter-spacing:1.5px;color:var(--plat);margin-top:3px}
.sb-price{font-family:"Space Mono",monospace;font-size:8.5px;letter-spacing:1px;color:var(--gld);margin-top:4px}
