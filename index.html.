const IU=(id,w=800,h=600)=>`https://images.unsplash.com/photo-${id}?w=${w}&h=${h}&q=80&auto=format&fit=crop`;
const POOL=["1502005097973-6a7082348e28","1493809842364-78817add7ffb","1560448204-e02f11c3d0e2","1564013799919-ab600027ffc6","1600596542815-ffad4c1539a9","1512917774080-9991f1c4c750","1486406146926-c627a92ad1ab","1600607687939-ce8a6c25118c"];
